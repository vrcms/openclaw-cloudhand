{
  "manifest_version": 3,
  "name": "Chrome Bridge",
  "version": "2.0.0",
  "description": "连接本地Chrome和远程AI助理",
  "permissions": [
    "tabs",
    "activeTab",
    "debugger",
    "cookies",
    "alarms",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Bridge"
  },
  "options_page": "options.html"
}
